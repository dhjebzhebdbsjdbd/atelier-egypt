---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatWhatsApp from '../components/FloatWhatsApp.astro';

interface Props {
  /** Browser tab title. */
  title?: string;
  /** Meta description (Arabic — the primary language). */
  description?: string;
}

const {
  title = 'أتيليه مصر — Atelier Egypt',
  description = 'أتيليه مصر — استوديو تصميم مواقع في القاهرة. نصمّم مواقع للبوتيكات والمطاعم والعيادات والعلامات التي تهتم بالتفاصيل.',
} = Astro.props;
---
<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#f4efe6" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=El+Messiri:wght@400;500;600;700&family=Tajawal:wght@200;300;400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Set language/direction before paint so there is no flash. -->
    <script is:inline>
      (function () {
        try {
          var l = localStorage.getItem('am-lang') === 'en' ? 'en' : 'ar';
          document.documentElement.lang = l;
          document.documentElement.dir = l === 'en' ? 'ltr' : 'rtl';
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <FloatWhatsApp />

    <script>
      import '../scripts/site.js';
    </script>
  </body>
</html>
