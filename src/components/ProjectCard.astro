---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}
const { project: p } = Astro.props;

const isExternal = !!p.url && p.url.startsWith('http');
const Tag = p.url ? 'a' : 'div';
const linkAttrs = p.url
  ? { href: p.url, ...(isExternal ? { target: '_blank', rel: 'noopener' } : {}) }
  : {};
---
<Tag class="project-card" {...linkAttrs}>
  <div class="thumb">
    {p.image
      ? <img src={p.image} alt={p.titleEn} loading="lazy" />
      : <span class="monogram">{p.monogram ?? 'أ'}</span>}
  </div>
  <div class="body">
    <span class="tag">
      <span data-ar>{p.tagAr}</span><span data-en>{p.tagEn}</span>
    </span>
    <h3>
      <span data-ar>{p.titleAr}</span><span data-en>{p.titleEn}</span>
    </h3>
    <p>
      <span data-ar>{p.descAr}</span><span data-en>{p.descEn}</span>
    </p>
  </div>
</Tag>
