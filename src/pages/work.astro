---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---
<Base title="أعمالنا — Atelier Masr">
  <section class="page-head wrap">
    <div class="sec-label">
      <span data-ar>أعمالنا</span><span data-en>Our work</span>
    </div>
    <h1 class="h1">
      <span data-ar>شغل نفخر<br>أن نوقّع <span class="accent">عليه</span>.</span>
      <span data-en>Work we're proud<br>to <span class="accent">sign</span>.</span>
    </h1>
    <p class="lede">
      <span data-ar>كل مشروع نشتغل عليه يبدأ بسؤال واحد: كيف نجعل هذه العلامة تبدو على حقيقتها؟</span>
      <span data-en>Every project we take on starts with one question: how do we make this brand look like its true self?</span>
    </p>
  </section>

  <section class="section tight wrap">
    <div class="work-grid reveal">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
    <p class="work-note reveal">
      <span data-ar>المعرض في طور النمو — مشاريع جديدة قادمة قريباً.</span>
      <span data-en>The portfolio is growing — new projects coming soon.</span>
    </p>
  </section>
</Base>
